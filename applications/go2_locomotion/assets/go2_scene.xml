<mujoco model="unitree_go2">
  <!-- Minimal Go2 MJCF model for RL locomotion research.
       Joint layout matches Unitree Go2 / mujoco_menagerie convention:
         FL: Front-Left,  FR: Front-Right
         RL: Rear-Left,   RR: Rear-Right
       Per leg: hip (abduction), thigh (flexion), calf (knee) = 12 DOF total
       nq=19 (7 freejoint + 12 joints), nv=18 (6 freejoint + 12), nu=12
  -->

  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81" iterations="50" solver="PGS"/>

  <default>
    <joint damping="0.05" armature="0.01"/>
    <geom contype="1" conaffinity="1" friction="0.8 0.02 0.001" rgba="0.7 0.7 0.7 1"/>
    <motor gear="1" ctrllimited="true" ctrlrange="-33.5 33.5"/>
    <default class="hip">
      <joint limited="true" range="-1.047 1.047" damping="0.2"/>
    </default>
    <default class="thigh">
      <joint limited="true" range="-1.5708 3.4907" damping="0.2"/>
    </default>
    <default class="calf">
      <joint limited="true" range="-2.7227 -0.8378" damping="0.2"/>
    </default>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" condim="3"/>

    <!-- Torso / base -->
    <body name="base" pos="0 0 0.45">
      <freejoint name="root"/>
      <inertial pos="0 0 0" mass="6.921"
                diaginertia="0.051 0.291 0.302"/>
      <geom type="box" size="0.267 0.097 0.057" rgba="0.2 0.2 0.2 1"/>
      <site name="base_site" pos="0 0 0" size="0.01"/>

      <!-- Front-Left leg -->
      <body name="FL_hip" pos="0.1934 0.0465 0">
        <inertial pos="0 0 0" mass="0.678" diaginertia="0.001 0.001 0.001"/>
        <joint name="FL_hip_joint" class="hip" axis="1 0 0"/>
        <geom type="capsule" size="0.023 0.02" pos="0 0.04 0" quat="0.707 0.707 0 0"/>
        <body name="FL_thigh" pos="0 0.0955 0">
          <inertial pos="0 0 -0.1" mass="1.152" diaginertia="0.003 0.003 0.001"/>
          <joint name="FL_thigh_joint" class="thigh" axis="0 1 0"/>
          <geom type="capsule" size="0.022 0.1" pos="0 0 -0.1" quat="0.707 0 0.707 0"/>
          <body name="FL_calf" pos="0 0 -0.213">
            <inertial pos="0 0 -0.1" mass="0.154" diaginertia="0.001 0.001 0.0001"/>
            <joint name="FL_calf_joint" class="calf" axis="0 1 0"/>
            <geom type="capsule" size="0.016 0.1" pos="0 0 -0.1" quat="0.707 0 0.707 0"/>
            <geom name="FL_foot" type="sphere" size="0.022" pos="0 0 -0.213" contype="1" conaffinity="1" rgba="0.9 0.6 0.1 1"/>
          </body>
        </body>
      </body>

      <!-- Front-Right leg -->
      <body name="FR_hip" pos="0.1934 -0.0465 0">
        <inertial pos="0 0 0" mass="0.678" diaginertia="0.001 0.001 0.001"/>
        <joint name="FR_hip_joint" class="hip" axis="1 0 0"/>
        <geom type="capsule" size="0.023 0.02" pos="0 -0.04 0" quat="0.707 0.707 0 0"/>
        <body name="FR_thigh" pos="0 -0.0955 0">
          <inertial pos="0 0 -0.1" mass="1.152" diaginertia="0.003 0.003 0.001"/>
          <joint name="FR_thigh_joint" class="thigh" axis="0 1 0"/>
          <geom type="capsule" size="0.022 0.1" pos="0 0 -0.1" quat="0.707 0 0.707 0"/>
          <body name="FR_calf" pos="0 0 -0.213">
            <inertial pos="0 0 -0.1" mass="0.154" diaginertia="0.001 0.001 0.0001"/>
            <joint name="FR_calf_joint" class="calf" axis="0 1 0"/>
            <geom type="capsule" size="0.016 0.1" pos="0 0 -0.1" quat="0.707 0 0.707 0"/>
            <geom name="FR_foot" type="sphere" size="0.022" pos="0 0 -0.213" contype="1" conaffinity="1" rgba="0.9 0.6 0.1 1"/>
          </body>
        </body>
      </body>

      <!-- Rear-Left leg -->
      <body name="RL_hip" pos="-0.1934 0.0465 0">
        <inertial pos="0 0 0" mass="0.678" diaginertia="0.001 0.001 0.001"/>
        <joint name="RL_hip_joint" class="hip" axis="1 0 0"/>
        <geom type="capsule" size="0.023 0.02" pos="0 0.04 0" quat="0.707 0.707 0 0"/>
        <body name="RL_thigh" pos="0 0.0955 0">
          <inertial pos="0 0 -0.1" mass="1.152" diaginertia="0.003 0.003 0.001"/>
          <joint name="RL_thigh_joint" class="thigh" axis="0 1 0"/>
          <geom type="capsule" size="0.022 0.1" pos="0 0 -0.1" quat="0.707 0 0.707 0"/>
          <body name="RL_calf" pos="0 0 -0.213">
            <inertial pos="0 0 -0.1" mass="0.154" diaginertia="0.001 0.001 0.0001"/>
            <joint name="RL_calf_joint" class="calf" axis="0 1 0"/>
            <geom type="capsule" size="0.016 0.1" pos="0 0 -0.1" quat="0.707 0 0.707 0"/>
            <geom name="RL_foot" type="sphere" size="0.022" pos="0 0 -0.213" contype="1" conaffinity="1" rgba="0.9 0.6 0.1 1"/>
          </body>
        </body>
      </body>

      <!-- Rear-Right leg -->
      <body name="RR_hip" pos="-0.1934 -0.0465 0">
        <inertial pos="0 0 0" mass="0.678" diaginertia="0.001 0.001 0.001"/>
        <joint name="RR_hip_joint" class="hip" axis="1 0 0"/>
        <geom type="capsule" size="0.023 0.02" pos="0 -0.04 0" quat="0.707 0.707 0 0"/>
        <body name="RR_thigh" pos="0 -0.0955 0">
          <inertial pos="0 0 -0.1" mass="1.152" diaginertia="0.003 0.003 0.001"/>
          <joint name="RR_thigh_joint" class="thigh" axis="0 1 0"/>
          <geom type="capsule" size="0.022 0.1" pos="0 0 -0.1" quat="0.707 0 0.707 0"/>
          <body name="RR_calf" pos="0 0 -0.213">
            <inertial pos="0 0 -0.1" mass="0.154" diaginertia="0.001 0.001 0.0001"/>
            <joint name="RR_calf_joint" class="calf" axis="0 1 0"/>
            <geom type="capsule" size="0.016 0.1" pos="0 0 -0.1" quat="0.707 0 0.707 0"/>
            <geom name="RR_foot" type="sphere" size="0.022" pos="0 0 -0.213" contype="1" conaffinity="1" rgba="0.9 0.6 0.1 1"/>
          </body>
        </body>
      </body>

    </body>
  </worldbody>

  <actuator>
    <!-- Hip joints (abduction) -->
    <motor name="FL_hip"   joint="FL_hip_joint"   gear="1" ctrlrange="-33.5 33.5"/>
    <motor name="FR_hip"   joint="FR_hip_joint"   gear="1" ctrlrange="-33.5 33.5"/>
    <motor name="RL_hip"   joint="RL_hip_joint"   gear="1" ctrlrange="-33.5 33.5"/>
    <motor name="RR_hip"   joint="RR_hip_joint"   gear="1" ctrlrange="-33.5 33.5"/>
    <!-- Thigh joints (flexion) -->
    <motor name="FL_thigh" joint="FL_thigh_joint" gear="1" ctrlrange="-33.5 33.5"/>
    <motor name="FR_thigh" joint="FR_thigh_joint" gear="1" ctrlrange="-33.5 33.5"/>
    <motor name="RL_thigh" joint="RL_thigh_joint" gear="1" ctrlrange="-33.5 33.5"/>
    <motor name="RR_thigh" joint="RR_thigh_joint" gear="1" ctrlrange="-33.5 33.5"/>
    <!-- Calf/knee joints -->
    <motor name="FL_calf"  joint="FL_calf_joint"  gear="1" ctrlrange="-33.5 33.5"/>
    <motor name="FR_calf"  joint="FR_calf_joint"  gear="1" ctrlrange="-33.5 33.5"/>
    <motor name="RL_calf"  joint="RL_calf_joint"  gear="1" ctrlrange="-33.5 33.5"/>
    <motor name="RR_calf"  joint="RR_calf_joint"  gear="1" ctrlrange="-33.5 33.5"/>
  </actuator>

  <sensor>
    <framequat name="base_quat"   objtype="site" objname="base_site"/>
    <framelinvel name="base_linvel" objtype="site" objname="base_site"/>
    <frameangvel name="base_angvel" objtype="site" objname="base_site"/>
    <jointpos name="FL_hip_pos"   joint="FL_hip_joint"/>
    <jointpos name="FR_hip_pos"   joint="FR_hip_joint"/>
    <jointpos name="RL_hip_pos"   joint="RL_hip_joint"/>
    <jointpos name="RR_hip_pos"   joint="RR_hip_joint"/>
    <jointpos name="FL_thigh_pos" joint="FL_thigh_joint"/>
    <jointpos name="FR_thigh_pos" joint="FR_thigh_joint"/>
    <jointpos name="RL_thigh_pos" joint="RL_thigh_joint"/>
    <jointpos name="RR_thigh_pos" joint="RR_thigh_joint"/>
    <jointpos name="FL_calf_pos"  joint="FL_calf_joint"/>
    <jointpos name="FR_calf_pos"  joint="FR_calf_joint"/>
    <jointpos name="RL_calf_pos"  joint="RL_calf_joint"/>
    <jointpos name="RR_calf_pos"  joint="RR_calf_joint"/>
    <jointvel name="FL_hip_vel"   joint="FL_hip_joint"/>
    <jointvel name="FR_hip_vel"   joint="FR_hip_joint"/>
    <jointvel name="RL_hip_vel"   joint="RL_hip_joint"/>
    <jointvel name="RR_hip_vel"   joint="RR_hip_joint"/>
    <jointvel name="FL_thigh_vel" joint="FL_thigh_joint"/>
    <jointvel name="FR_thigh_vel" joint="FR_thigh_joint"/>
    <jointvel name="RL_thigh_vel" joint="RL_thigh_joint"/>
    <jointvel name="RR_thigh_vel" joint="RR_thigh_joint"/>
    <jointvel name="FL_calf_vel"  joint="FL_calf_joint"/>
    <jointvel name="FR_calf_vel"  joint="FR_calf_joint"/>
    <jointvel name="RL_calf_vel"  joint="RL_calf_joint"/>
    <jointvel name="RR_calf_vel"  joint="RR_calf_joint"/>
  </sensor>


</mujoco>
